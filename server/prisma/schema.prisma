datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  surName   String
  lastName  String?
  avatar    String?
  
  roleId    Int?     
  role      Role?    @relation(fields: [roleId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique  
  users User[] 
}
