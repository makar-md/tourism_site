datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  surName   String
  lastName  String?
  avatar    String?
  
  roleId    Int?     
  role      Role?    @relation(fields: [roleId], references: [id])

  route    Routes[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique  
  users User[] 
}

model Routes{
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String? 
  isPublic    Boolean
  statusId    Int?
  status      RoutStatus?  @relation(fields: [statusId], references: [id]) 
  points      Point[]
  images      RoutesImg[]
  userId      String
  user        User   @relation(fields: [userId], references: [id])
}

model Point{
  id        Int    @id @default(autoincrement())
  lng       Float
  lat       Float
  routeId   Int     
  route     Routes    @relation(fields: [routeId], references: [id])
}

model RoutesImg{
  id        Int    @id @default(autoincrement())
  img       String
  routeId   Int     
  route     Routes    @relation(fields: [routeId], references: [id])
}

model RoutStatus {
  id    Int    @id @default(autoincrement())
  name  String @unique  
  routes Routes[] 
}
