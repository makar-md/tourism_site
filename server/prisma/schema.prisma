datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  firstName     String
  surName       String
  lastName      String?
  avatar        String?
  
  roleId        Int?     
  role          Role?    @relation(fields: [roleId], references: [id])

  route         Routes[]
  historyyRoute HistoryRoutes[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique  
  users User[] 
}

model Routes{
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String? 
  isPublic    Boolean
  statusId    Int?
  status      RoutStatus?  @relation(fields: [statusId], references: [id]) 
  points      Point[]
  images      RoutesImg[]
  userId      String
  user        User   @relation(fields: [userId], references: [id])
  Versions    HistoryRoutes[]
}

model Point{
  id        Int    @id @default(autoincrement())
  lng       Float
  lat       Float
  routeId   Int     
  route     Routes    @relation(fields: [routeId], references: [id], onDelete: Cascade)
}

model RoutesImg{
  id        Int    @id @default(autoincrement())
  img       String
  routeId   Int     
  route     Routes    @relation(fields: [routeId], references: [id], onDelete: Cascade)
}

model RoutStatus {
  id            Int    @id @default(autoincrement())
  name          String @unique  
  routes        Routes[] 
  historyyRoute HistoryRoutes[]
}

// история измениния маршрутов

model HistoryRoutes {
    id          Int      @id @default(autoincrement())

    routeId     Int
    route       Routes   @relation(fields: [routeId], references: [id], onDelete: Cascade)

    version     Int

    name        String
    description String?
    isPublic    Boolean

    statusId    Int?
    status      RoutStatus? @relation(fields: [statusId], references: [id])

    userId      String
    user        User @relation(fields: [userId], references: [id])

    points      HistoryPoint[]
    images      HistoryRoutesImg[]
    @@unique([routeId, version])
}

model HistoryPoint {
    id        Int @id @default(autoincrement())
    lng Float
    lat Float
    historyId Int
    history HistoryRoutes @relation(fields: [historyId], references: [id], onDelete: Cascade)
}

model HistoryRoutesImg {
    id Int @id @default(autoincrement())
    img String
    historyId Int
    history HistoryRoutes @relation(fields: [historyId], references: [id], onDelete: Cascade)
}
